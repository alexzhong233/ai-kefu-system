# DashScope API 配置（必填）
# 从 https://dashscope.console.aliyun.com/ 获取
AI_DASHSCOPE_API_KEY=sk-your-api-key-here

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aikefu
DB_USER=postgres
DB_PASSWORD=your-db-password-here

# 服务端口
SERVER_PORT=8080

# 模型配置（可选，以下为默认值）
# DASHSCOPE_CHAT_MODEL=deepseek-v4-flash
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
